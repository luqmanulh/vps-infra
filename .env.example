# =============================================================================
# VPS Infrastructure Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains sensitive credentials!
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL SETTINGS
# -----------------------------------------------------------------------------

# Your domain name (replace example.com with your actual domain)
DOMAIN=example.com

# Email for Let's Encrypt certificates (required for ACME)
LETSENCRYPT_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# TRAEFIK (Reverse Proxy)
# -----------------------------------------------------------------------------

# Traefik dashboard credentials (optional, bcrypt hashed)
# Generate with: htpasswd -nb admin your-password | openssl base64
# TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xyz$$abc

# -----------------------------------------------------------------------------
# FORGEJO (Git Server)
# -----------------------------------------------------------------------------

# Forgejo domain (subdomain of your DOMAIN)
FORGEJO_DOMAIN=git.${DOMAIN}

# SSH port for Git operations (use non-standard port for security)
# Default: 1234 - CHANGE THIS to your actual VPS SSH port
FORGEJO_SSH_PORT=1234

# HTTP port for Forgejo web UI
FORGEJO_HTTP_PORT=3000

# Forgejo database (internal, don't change unless needed)
FORGEJO_DB_TYPE=sqlite3

# Forgejo admin credentials (CHANGE THESE!)
FORGEJO_ADMIN_USER=admin
FORGEJO_ADMIN_PASSWORD=change-me-123
FORGEJO_ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# FORGEJO ACTIONS RUNNER
# -----------------------------------------------------------------------------

# Runner name (visible in Forgejo Actions settings)
RUNNER_NAME=forgejo-runner

# Runner labels (for job targeting)
RUNNER_LABELS=ubuntu-latest

# Runner token (get from Forgejo UI: Settings → Actions → Add Runner)
# This is sensitive - generate fresh for each setup
RUNNER_TOKEN=your-runner-token-here

# Runner work directory
RUNNER_WORKDIR=/data

# -----------------------------------------------------------------------------
# UPTIME KUMA (Monitoring)
# -----------------------------------------------------------------------------

# Uptime Kuma HTTP port
UPTIME_KUMA_PORT=3001

# Uptime Kuma database type (sqlite or mysql)
UPTIME_KUMA_DB_TYPE=sqlite

# -----------------------------------------------------------------------------
# HELLO-DEVOPS (Demo App)
# -----------------------------------------------------------------------------

# Demo app domain
HELLO_DEVOPS_HOST=hello.${DOMAIN}
n# --- MONITORING ---
GRAFANA_HOST=grafana.${DOMAIN}
PROMETHEUS_HOST=prometheus.${DOMAIN}
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change...n

# App version (set by CI/CD)
APP_VERSION=1.0.0-dev

# -----------------------------------------------------------------------------
# SSH DEPLOYMENT
# -----------------------------------------------------------------------------

# VPS SSH port (for CI/CD deployment)
VPS_SSH_PORT=1234

# Deploy user (created on VPS for CI/CD)
DEPLOY_USER=deploy

# -----------------------------------------------------------------------------
# SECURITY NOTES
# -----------------------------------------------------------------------------
# - Change all default passwords before production use
# - Use strong passwords (16+ chars, mix of upper/lower/numbers/symbols)
# - Rotate RUNNER_TOKEN periodically
# - Keep TRAEFIK_ACME_EMAIL valid (for certificate renewal notifications)
# - Use fail2ban on VPS for SSH brute-force protection
# - Regular backups of /data directories
# =============================================================================
